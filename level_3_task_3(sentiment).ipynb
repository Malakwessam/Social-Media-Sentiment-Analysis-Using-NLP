"""# Loading Dataset"""

df = pd.read_csv("3) Sentiment dataset.csv")

"""# Cleaning

*   redundant time-related columns (Year, Month, Day, Hour) were dropped since the same information is already contained in the Timestamp column
*   ‘Unnamed: 0.1’ and ‘Unnamed: 0’ were removed because they represent unnecessary index column
"""

df = df.drop(['Unnamed: 0.1','Unnamed: 0','Year', 'Month', 'Day', 'Hour'], axis=1)

df.head()

df.info()

df['Timestamp'] = pd.to_datetime(df['Timestamp'], errors='coerce') #invalid date -->NaT

df.duplicated().sum()

df = df.drop_duplicates()
df.duplicated().sum()

df['Text'] = df['Text'].str.strip()
df['Sentiment'] = df['Sentiment'].str.strip()
df['Platform'] = df['Platform'].str.strip().str.lower()
df['Country'] = df['Country'].str.strip().str.title() #capitalizes

"""# Pre-processing

### Convert to lowercase + remove punctuation
"""

def clean_text(text):
    text = text.lower()
    text = re.sub(r'[^a-zA-Z\s]', '', text)
    return text

df['clean_text'] = df['Text'].apply(clean_text)

"""### Tokenization"""

df['tokens'] = df['clean_text'].apply(word_tokenize)

df.head()

"""### Stopwords Removal"""

stop_words = set(stopwords.words('english'))

def remove_stopwords(tokens):
    return [word for word in tokens if word not in stop_words]

df['tokens'] = df['tokens'].apply(remove_stopwords)

df.head()

"""### Lemmatization"""

lemmatizer = WordNetLemmatizer()

def lemmatize(tokens):
    return [lemmatizer.lemmatize(word) for word in tokens] #change plural nouns

df['tokens'] = df['tokens'].apply(lemmatize)

df['processed_text'] = df['tokens'].apply(lambda x: " ".join(x))

df.head(10)

def get_sentiment(processed_text):
    analysis = TextBlob(processed_text)

    if analysis.sentiment.polarity > 0:
        return "Positive"
    elif analysis.sentiment.polarity < 0:
        return "Negative"
    else:
        return "Neutral"

df['Predicted_Sentiment'] = df['processed_text'].apply(get_sentiment)

df[['processed_text', 'Predicted_Sentiment']].head()

df['Predicted_Sentiment'].value_counts().plot(kind='bar')

plt.title("Sentiment Distribution")
plt.xlabel("Sentiment")
plt.ylabel("Count")

plt.show()

